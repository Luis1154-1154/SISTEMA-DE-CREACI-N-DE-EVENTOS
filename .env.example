# Example environment variables for local development and production
# Database (PlanetScale/Render/Railway)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clinic_db
DB_CONN_LIMIT=10
# If your DB requires TLS/SSL (e.g., PlanetScale), set DB_SSL=true and optionally DB_SSL_REJECT_UNAUTHORIZED=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
# If you need to provide a CA certificate, you can set DB_SSL_CA to the file path or base64-encoded PEM content
# DB_SSL_CA=/path/to/ca.pem

# JWT secret for signing session cookies (change in production)
JWT_SECRET=change_me_to_a_long_random_string

# Node server port
PORT=3000
NODE_ENV=development
